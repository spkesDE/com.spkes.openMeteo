{
  "title": {
    "en": "Create chart for Weather Variable",
    "de": "Erstelle ein Diagramm fuer Wetterwerte"
  },
  "titleFormatted": {
    "en": "Create chart for [[weatherVariable]] over [[period]] ([[type]] [[lineColor]] [[backgroundColor]])",
    "de": "Erstelle ein Diagramm fuer [[weatherVariable]] ueber [[period]] ([[type]] [[lineColor]] [[backgroundColor]])"
  },
  "args": [
    {
      "type": "device",
      "name": "device",
      "filter": "driver_id=weather"
    },
    {
      "type": "autocomplete",
      "required": false,
      "name": "weatherVariable",
      "placeholder": {
        "en": "Weather Variable",
        "de": "Wetterwert"
      }
    },
    {
      "name": "period",
      "type": "dropdown",
      "title": {
        "en": "Period",
        "de": "Zeitraum"
      },
      "values": [
        {
          "id": "auto",
          "title": {
            "en": "Auto",
            "de": "Automatisch"
          }
        },
        {
          "id": "24h",
          "title": {
            "en": "24 hours",
            "de": "24 Stunden"
          }
        },
        {
          "id": "48h",
          "title": {
            "en": "48 hours",
            "de": "48 Stunden"
          }
        },
        {
          "id": "7d",
          "title": {
            "en": "7 days",
            "de": "7 Tage"
          }
        },
        {
          "id": "14d",
          "title": {
            "en": "14 days",
            "de": "14 Tage"
          }
        },
        {
          "id": "16d",
          "title": {
            "en": "16 days",
            "de": "16 Tage"
          }
        }
      ]
    },
    {
      "name": "type",
      "type": "dropdown",
      "title": {
        "en": "Type",
        "de": "Typ"
      },
      "values": [
        {
          "id": "line",
          "title": {
            "en": "Line Chart",
            "de": "Liniendiagramm"
          }
        },
        {
          "id": "bar",
          "title": {
            "en": "Bar Chart",
            "de": "Balkendiagramm"
          }
        }
      ]
    },
    {
      "type": "color",
      "name": "lineColor",
      "required": false,
      "title": {
        "en": "Color",
        "de": "Farbe"
      }
    },
    {
      "name": "backgroundColor",
      "type": "dropdown",
      "required": false,
      "title": {
        "en": "Background Color",
        "de": "Hintergrundfarbe"
      },
      "values": [
        {
          "id": "#ffffff",
          "title": {
            "en": "Light Mode",
            "de": "Heller Modus"
          }
        },
        {
          "id": "#222329",
          "title": {
            "en": "Dark Mode",
            "de": "Dunkler Modus"
          }
        },
        {
          "id": "transparent",
          "title": {
            "en": "Transparent Mode",
            "de": "Transparenter Modus"
          }
        }
      ]
    }
  ],
  "tokens": [
    {
      "name": "chart",
      "type": "image",
      "title": {
        "en": "Chart",
        "de": "Diagramm"
      }
    }
  ]
}
